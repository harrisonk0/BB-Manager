# Client (Vite) environment variables
# These are embedded into the browser bundle at build time.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Playwright smoke-test credentials
# These are only used by local/CI browser smoke tests.
E2E_TEST_EMAIL=test-user@example.com
E2E_TEST_PASSWORD=CHANGE_ME
